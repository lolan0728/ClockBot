{
  "manifest_version": 3,
  "name": "ClockBot Chrome Extension",
  "version": "0.1.0",
  "description": "Runs IEYASU attendance actions inside the user's regular Chrome session for ClockBot.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "activeTab",
    "debugger",
    "alarms"
  ],
  "host_permissions": [
    "https://*.ieyasu.co/*",
    "http://127.0.0.1:38473/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "ClockBot",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
